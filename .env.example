# آراما — Required Environment Variables
# =======================================

# PostgreSQL connection string (required)
# Example: postgresql://postgres:postgres@127.0.0.1:5432/app_db
# For production with SSL: postgresql://user:pass@host:5432/db?sslmode=verify-full
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/app_db

# OpenAI API (optional — without it, the app uses a fallback reply)
# Get one at https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-xxxxxxxxxxxxx
# OPENAI_API_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini

# MeliPayamak SMS Gateway (for OTP authentication)
# Get credentials at https://melipayamak.ir/
MELIPAYAMAK_USERNAME=your_username
MELIPAYAMAK_PASSWORD=your_password
MELIPAYAMAK_FROM=your_from_number

# Session cookie configuration (leave default for local development)
# NODE_ENV=production

# Base URL for callback redirects and startPay (required for ZarinPal integration)
# Example: https://my-app.com or http://localhost:3000 (no trailing slash)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ZarinPal Payment Gateway
# Your Merchant ID (must be a valid UUID. For sandbox testing, use 36 zeros)
ZARINPAL_MERCHANT_ID=00000000-0000-0000-0000-000000000000
# Sandbox mode (true/false) - if true, payments are requested from sandbox.zarinpal.com
ZARINPAL_SANDBOX=true
